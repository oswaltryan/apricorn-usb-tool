#!/bin/sh
set -e

. /usr/share/debconf/confmodule

BIN_DIR="/usr/local/lib/apricorn-usb-toolkit"
LEGACY_BIN_DIR="/usr/local/lib/usb-tool"
LINK_TARGET="/usr/local/bin/usb"
SUDOERS_FILE="/etc/sudoers.d/usb-tool-nopasswd"
QUESTION="usb-tool/install_nopasswd_sudo"

if [ ! -d "$BIN_DIR" ]; then
    mkdir -p "$BIN_DIR"
fi

if [ ! -x "$BIN_DIR/usb" ] && [ -x "$LEGACY_BIN_DIR/usb" ]; then
    mv "$LEGACY_BIN_DIR/usb" "$BIN_DIR/usb" 2>/dev/null || true
fi

if [ ! -x "$BIN_DIR/usb" ]; then
    chmod 755 "$BIN_DIR/usb" 2>/dev/null || true
fi

ln -sf "$BIN_DIR/usb" "$LINK_TARGET"

if [ -d "$LEGACY_BIN_DIR" ]; then
    rm -f "$LEGACY_BIN_DIR/usb"
    rmdir "$LEGACY_BIN_DIR" 2>/dev/null || true
fi

if db_get "$QUESTION" && [ "$RET" = "true" ]; then
    if [ -x /usr/sbin/visudo ] && [ -d /etc/sudoers.d ]; then
        tmp_file="${SUDOERS_FILE}.tmp"
        cat >"$tmp_file" <<EOF
ALL ALL=(root) NOPASSWD: /usr/local/bin/usb
EOF
        chmod 0440 "$tmp_file"
        chown root:root "$tmp_file"
        if /usr/sbin/visudo -cf "$tmp_file" >/dev/null 2>&1; then
            mv "$tmp_file" "$SUDOERS_FILE"
        else
            rm -f "$tmp_file"
            echo "apricorn-usb-toolkit: generated sudoers file failed validation; skipping NOPASSWD setup." >&2
        fi
    fi
else
    rm -f "$SUDOERS_FILE"
fi

exit 0
