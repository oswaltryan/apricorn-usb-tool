#!/bin/sh
set -e

LINK_TARGET="/usr/local/bin/usb"

if [ -L "$LINK_TARGET" ]; then
    CURRENT_TARGET=$(readlink "$LINK_TARGET" 2>/dev/null || true)
    case "$CURRENT_TARGET" in
        *apricorn-usb-toolkit/usb|\
        *usb-tool/usb)
            rm -f "$LINK_TARGET"
            ;;
    esac
fi

exit 0
